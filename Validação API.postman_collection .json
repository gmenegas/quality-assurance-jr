{
  "info": {
    "_postman_id": "ce0d54d3-bb76-4299-8f7a-7a6ccb7850fe",
    "name": "Validação API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "51180825"
  },
  "item": [
    {
      "name": "Validação API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "\r",
              "//Validação de resposta\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Tempo deve ser < 600ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(600)\r",
              "});\r",
              "\r",
              "// Validação de estrutura\r",
              "\r",
              "pm.test(\"Resposta é um array não vazio\", function () {\r",
              "    pm.expect(jsonData).to.be.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Campos obrigatorios estão presentes\", function () {\r",
              "    jsonData.forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"id\");\r",
              "        pm.expect(item).to.have.property(\"title\");\r",
              "        pm.expect(item).to.have.property(\"dueDate\");\r",
              "        pm.expect(item).to.have.property(\"completed\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se o tipo de dado é correto\", function () {\r",
              "    jsonData.forEach(item => {\r",
              "        pm.expect(item.id).to.be.a('number');\r",
              "        pm.expect(item.title).to.be.a('string');\r",
              "        pm.expect(item.dueDate).to.be.a('string');\r",
              "        pm.expect(item.completed).to.be.a('boolean');\r",
              "\r",
              "    });\r",
              "});\r",
              "\r",
              "//Validação regra de negócio\r",
              "\r",
              "pm.test(\"Campo Título não pode ser vazio\", function () {\r",
              "    jsonData.forEach((item, index) => {\r",
              "        pm.expect(item.title, `Erro no item ${index}`)\r",
              "            .to.be.a(\"string\")\r",
              "            .and.to.not.be.empty;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Campo Completed deve ser booleano\", function () {\r",
              "    jsonData.forEach((item, index) => {\r",
              "        pm.expect(item.completed, `Erro no item ${index}`)\r",
              "            .to.be.a(\"boolean\");\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"ID deve ser positivo\", function () {\r",
              "    jsonData.forEach(item => {\r",
              "        pm.expect(item.id).to.be.above(0);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"dueDate deve ser uma data válida\", function () {\r",
              "    jsonData.forEach(item => {\r",
              "        const date = new Date(item.dueDate);\r",
              "        pm.expect(date.toString()).to.not.eql(\"Invalid Date\");\r",
              "    });\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{Baseurl}}api/v1/Activities",
          "host": [
            "{{Baseurl}}api"
          ],
          "path": [
            "v1",
            "Activities"
          ]
        }
      },
      "response": []
    }
  ]
}